# Contoh konfigurasi lingkungan
# Jangan commit rahasia nyata. Berkas ini hanya untuk pengembangan lokal.

# Tingkat logging (lihat src/utils/logger.ts). Contoh: debug, info, warn, error
LOG_LEVEL=info

# Host dan port API
API_HOST=localhost
API_PORT=3000
DASHBOARD_PORT=3001

# Path database
DATABASE_PATH=data/app.db

# Rahasia JWT untuk penandatangan token (JANGAN commit rahasia nyata; ganti di env lokal)
JWT_SECRET=CHANGE_ME_JWT_SECRET

# ─── WhatsApp via Waha (HTTP API yang di-hosting sendiri) ────────────────────────
# Jalankan Waha dengan: docker run -p 3001:3000 devlikeapro/waha
WAHA_BASE_URL=http://localhost:3001
WAHA_API_KEY=your-waha-api-key
WAHA_SESSION=default

# Token API WhatsApp Cloud (opsional, hanya digunakan jika WAHA_BASE_URL tidak diset)
# WHATSAPP_CLOUD_API_TOKEN=

# ─── Telegram Bot API (adaptor Telegraf yang ada) ────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token

# ─── Telegram MTProto / Akun User (gaya gramjs / Telethon) ───────────────
# Dapatkan apiId + apiHash dari https://my.telegram.org
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your-api-hash
# String sesi: hasilkan sekali dengan skrip login satu kali, simpan terenkripsi
TELEGRAM_SESSION=your-session-string

# ─── Kuki media sosial (adaptor berbasis kuki IG, Twitter, Threads) ───────
# Nilai kuki disimpan per-akun di dasbor (terenkripsi di DB).
# Tidak perlu variabel env — atur kuki via POST /v1/accounts dengan kolom kredensial.

# ─── Instagram Graph API (adaptor ada, opsional) ─────────────────────────
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_BUSINESS_ACCOUNT_ID=
# INSTAGRAM_ALLOW_PRIVATE_API=false

# ─── Twitter/X API (adaptor ada, opsional) ───────────────────────────────
# TWITTER_BEARER_TOKEN=
# TWITTER_API_KEY=
# TWITTER_API_SECRET=

# ─── Threads Graph API (adaptor ada, opsional) ───────────────────────────
# THREADS_ACCESS_TOKEN=
