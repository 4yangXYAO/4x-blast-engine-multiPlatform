{
  "name": "joki-blast-engine",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "description": "Mesin blast produksi berfokus Node.js/TypeScript dengan dashboard Next.js, persistensi SQLite, dan adaptor platform untuk WhatsApp, Telegram, Instagram, Twitter/X, Threads, dan Facebook Pages.",
  "engines": {
    "node": ">=20.20.0 <21"
  },
  "scripts": {
    "db:init": "ts-node ./scripts/db-init.ts",
    "db:validate": "node ./scripts/db-validate.ts",
    "validate:config": "node -r dotenv/config -r ts-node/register ./scripts/validate-config.js",
    "dev:api": "node -r dotenv/config -r ts-node/register/transpile-only -e \"require('./src/api/server').startServer()\"",
    "lint": "eslint 'src/**/*.{ts,tsx}' 'scripts/**/*.{ts,tsx}' --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "async-mutex": "^0.3.2",
    "axios": "^1.15.2",
    "better-sqlite3": "^12.9.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "facebook-chat-api": "^1.8.0",
    "fca-unofficial": "^1.3.10",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "playwright": "^1.59.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sql.js": "^1.14.1",
    "telegram": "^2.26.22",
    "twitter-api-v2": "^1.29.0",
    "winston": "^3.9.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/axios": "^0.14.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.18",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/puppeteer": "^5.4.7",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^0.34.1",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.29.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "vitest": "^0.34.1"
  }
}
